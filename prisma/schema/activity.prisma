enum ActivityAction {
  PROJECT_CREATED
  PROJECT_UPDATED
  PROJECT_DELETED
  TASK_CREATED
  TASK_UPDATED
  TASK_DELETED
  TASK_ASSIGNED
  TASK_STATUS_CHANGED
  MEMBER_ADDED
  MEMBER_REMOVED
  COMMENT_ADDED
  COMMENT_DELETED
  ATTACHMENT_ADDED
  USER_LOGIN
  USER_LOGOUT
  USER_REGISTER
}

model Activity {
  id          String         @id @default(uuid())
  action      ActivityAction
  message     String         @db.Text
  details     Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime       @default(now())

  // Foreign Keys
  userId      String
  projectId   String?
  taskId      String?

  // Relations
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task        Task?          @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
  @@index([taskId])
  @@index([action])
  @@index([createdAt])
  @@map("activities")
}