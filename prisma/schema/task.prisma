enum Priority {
  HIGH
  MEDIUM
  LOW
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
}

model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  dueDate     DateTime
  priority    Priority   @default(MEDIUM)
  status      TaskStatus @default(TODO)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Foreign Keys
  assignedTo  String?
  projectId   String

  // Relations
  assignedUser User?      @relation("TaskAssignee", fields: [assignedTo], references: [id])
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  activities   Activity[]
  comments     Comment[]
  attachments  Attachment[]

  @@unique([projectId, title])  // Prevent duplicate task titles in same project
  @@index([projectId])
  @@index([assignedTo])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@map("tasks")
}